# Copy this file to .env and fill in your real values.
# Get a free API key at https://platform.devdarsha.com
#
#   cp .env.example .env
#   set -a
#   source .env
#   set +a
#
# .env is gitignored — never commit your real key.

# Your DevDarsha Panchang API key (sent as the X-Api-Key header).
DEVDARSHA_API_KEY=your_api_key_here

# Location by city. `city_id` works on every plan (including Free).
# Coordinate lookups (lat/lon) require an Amethyst plan or higher.
DEVDARSHA_CITY_ID=ujjain

# The date to query, in YYYY-MM-DD format.
DEVDARSHA_DATE=2026-04-15

# Month (YYYY-MM) for the monthly example — needs an Amethyst plan or higher.
DEVDARSHA_MONTH=2026-06

# Year (1900–2100) for the yearly example — needs a Sapphire plan or higher.
DEVDARSHA_YEAR=2026
